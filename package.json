{
	"name": "cursor-free-plus",
	"displayName": "Superman MCP",
	"description": "Superman MCP：Cursor 侧栏多路 MCP（check_messages / send_message / ask_question，多窗口独立会话），并附带会员类型与账单相关工具页（仅供学习研究，请遵守 Cursor 服务条款）。",
	"version": "1.4.0",
	"publisher": "cursor-free",
	"license": "MIT",
	"keywords": [
		"mcp",
		"cursor",
		"model context protocol",
		"multi-session",
		"sidebar",
		"membership",
		"cursor-free",
		"wukong",
		"chat",
		"check_messages"
	],
	"categories": [
		"Other"
	],
	"engines": {
		"vscode": "^1.71.0"
	},
	"main": "./dist/extension.js",
	"activationEvents": [
		"onView:my.cursorMyUi",
		"onCommand:my.cursorMyUi.configureWorkspace",
		"onCommand:my.cursorMyUi.openMainPanel",
		"onCommand:cursorFree.applyMembershipPatch",
		"onCommand:cursorFree.restoreMembership",
		"onCommand:cursorFree.detectCursorPath",
		"onCommand:cursorFree.openMembershipPage",
		"onCommand:cursorFree.openBillingPage"
	],
	"contributes": {
		"commands": [
			{
				"command": "my.cursorMyUi.configureWorkspace",
				"title": "配置工作区（MCP）",
				"category": "Superman MCP"
			},
			{
				"command": "my.cursorMyUi.openMainPanel",
				"title": "打开主面板（独立页签）",
				"category": "Superman MCP"
			},
			{
				"command": "cursorFree.applyMembershipPatch",
				"title": "应用会员补丁",
				"category": "Superman MCP"
			},
			{
				"command": "cursorFree.restoreMembership",
				"title": "恢复原始会员文件",
				"category": "Superman MCP"
			},
			{
				"command": "cursorFree.detectCursorPath",
				"title": "检测 Cursor 安装路径",
				"category": "Superman MCP"
			},
			{
				"command": "cursorFree.openMembershipPage",
				"title": "打开会员类型设置",
				"category": "Superman MCP"
			},
			{
				"command": "cursorFree.openBillingPage",
				"title": "打开账单与用量",
				"category": "Superman MCP"
			}
		],
		"configuration": {
			"title": "Superman MCP",
			"properties": {
				"wukong.licenseSecret": {
					"type": "string",
					"default": "",
					"description": "[已弃用] 免卡密版本不再使用此密钥，仅为兼容保留。"
				},
				"wukong.adminPassword": {
					"type": "string",
					"default": "",
					"description": "[已弃用] 免卡密版本不再使用管理员密码，仅为兼容保留。"
				},
				"wukong.redeemApiBaseUrl": {
					"type": "string",
					"default": "",
					"description": "[已弃用] 免卡密版本不再请求云端核销，仅为兼容保留。"
				},
				"wukong.payStoreUrl": {
					"type": "string",
					"default": "https://pay.ldxp.cn/shop/superman",
					"description": "侧栏「在线购买」按钮跳转的支付页 URL。"
				},
				"wukong.redeemTimeoutMs": {
					"type": "number",
					"default": 20000,
					"description": "[已弃用] 免卡密版本不再请求云端核销，仅为兼容保留。"
				},
				"wukong.cloudLicenseOnly": {
					"type": "boolean",
					"default": false,
					"description": "[已弃用] 免卡密版本恒为 false。"
				},
				"wukong.cloudLicenseVerifyIntervalMs": {
					"type": "number",
					"default": 900000,
					"description": "[已弃用] 免卡密版本不再发起吊销校验。"
				},
				"cursorFree.supportGroupQQ": {
					"type": "string",
					"default": "1087432681",
					"description": "交流群 QQ 号，显示在侧栏底部。"
				},
				"cursorFree.defaultMembership": {
					"type": "string",
					"enum": [
						"free",
						"free_trial",
						"pro",
						"pro_plus",
						"ultra",
						"enterprise"
					],
					"default": "pro",
					"description": "默认选中的会员类型。"
				}
			}
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "wukong-mcp",
					"title": "Superman MCP",
					"icon": "resources/icon.svg"
				}
			]
		},
		"views": {
			"wukong-mcp": [
				{
					"type": "webview",
					"id": "my.cursorMyUi",
					"name": "Superman MCP"
				}
			]
		}
	},
	"scripts": {
		"compile": "tsc -p . && node scripts/copy-vendor.js",
		"watch": "tsc -p . -w",
		"vendor": "node scripts/copy-vendor.js",
		"package": "npm run compile && vsce package --no-dependencies --allow-missing-repository",
		"postinstall": "cd mcp-server && npm install"
	},
	"devDependencies": {
		"@types/node": "^16.18.0",
		"@types/vscode": "^1.71.0",
		"@vscode/vsce": "^3.7.0",
		"ts-node": "^10.9.2",
		"typescript": "^4.7.4"
	},
	"dependencies": {
		"sql.js": "^1.14.1"
	}
}
